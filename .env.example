# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV: use the docker-compose postgres instance
DATABASE_URL=postgresql://contextos:contextos_dev@localhost:5432/contextos

# PRODUCTION (Supabase):
# DATABASE_URL         = Session Pooler URL  (Supavisor, port 5432)
#   Used by: mcp-server, hooks-bridge, web, nl-assembly, semantic-diff
#   Format: postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# DATABASE_URL_MIGRATE = Direct Connection URL (port 5432, db.xxx.supabase.co)
#   Used by: drizzle-kit migrate ONLY — DDL is not safe through connection poolers
#   Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
# DATABASE_URL_MIGRATE falls back to DATABASE_URL when not set (fine for local dev).
DATABASE_URL_MIGRATE=

# ── Redis ─────────────────────────────────────────────────────────────────────
# LOCAL DEV: use the docker-compose redis instance
REDIS_URL=redis://localhost:6379

# PRODUCTION (Upstash Redis):
# Use the ioredis-compatible TLS URL from Upstash dashboard:
#   REDIS_URL=rediss://:[token]@[hostname]:6380
# Upstash provides serverless Redis with TLS, no VPC required, BullMQ-compatible.
BULLMQ_REDIS_URL=redis://localhost:6379

# Auth
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# MCP Server
MCP_SERVER_PORT=3100

# Hooks Bridge
HOOKS_BRIDGE_PORT=3101

# NL Assembly (Python)
NL_ASSEMBLY_URL=http://localhost:3200
NL_ASSEMBLY_PORT=3200
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Semantic Diff (Python)
SEMANTIC_DIFF_URL=http://localhost:3201
SEMANTIC_DIFF_PORT=3201
ANTHROPIC_API_KEY=sk-ant-replace_me

# Logging
LOG_LEVEL=info
