    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.30.0",
    "testcontainers": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
