{
  "name": "@contextos/hooks-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test:unit": "vitest run --reporter=verbose __tests__/unit",
    "test:integration": "vitest run --reporter=verbose __tests__/integration",
    "test:e2e": "vitest run --reporter=verbose __tests__/e2e"
  },
  "dependencies": {
    "@contextos/shared": "workspace:*",
    "@contextos/db": "workspace:*",
    "@clerk/backend": "^1.0.0",
    "@hono/zod-validator": "^0.4.0",
    "bullmq": "^5.51.0",
    "hono": "^4.7.0",
    "ioredis": "^5.3.0",
    "micromatch": "^4.0.8",
    "pino": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
